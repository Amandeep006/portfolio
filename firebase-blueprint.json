{
  "entities": {
    "ContactSubmission": {
      "title": "Contact Submission",
      "description": "A message submitted via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the sender." },
        "email": { "type": "string", "format": "email", "description": "The email of the sender." },
        "subject": { "type": "string", "description": "The subject of the message." },
        "message": { "type": "string", "description": "The message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "uid": { "type": "string", "description": "The UID of the user (if authenticated)." }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "UserConfig": {
      "title": "User Config",
      "description": "Configuration for the user, including Google Drive tokens.",
      "type": "object",
      "properties": {
        "googleTokens": { "type": "object", "description": "OAuth2 tokens for Google Drive." },
        "spreadsheetId": { "type": "string", "description": "The ID of the Google Sheet in Drive." }
      }
    }
  },
  "firestore": {
    "submissions": {
      "schema": "ContactSubmission",
      "description": "Collection of contact form submissions."
    },
    "configs": {
      "schema": "UserConfig",
      "description": "User-specific configuration and secrets."
    }
  }
}
